{
    "input_csaf_revision": "2.0-errata01",
    "output_csaf_revision": "2.1-cs02",
    "converter_tests" : [
        { "input": "testcase-1-20260311-1512-isduba-2026-001.json",
          "desc": "testing the removal of an additional property",
          "asserts" : [
              { "type": "warningmsg",
                "substring_matches": ["additional property", "not converted"]
              },
              { "type": "jsonpath",
                "query": "$.document.x_test_q7VQf",
                "expected_result": []
              },
              { "type": "success",
                "value" : true
              }
          ]
        },

        { "input": "testcase-2-20260312-1651-isduba-2025-01.json",
          "asserts" : [
              { "type": "warningmsg",
                "substring_matches": [
                    "valid leap second", "prohibited", "replaced"]
              },
              { "type": "jsonpath",
                "query": "$..[?search(@.date, ':60[Z+-]')].date",
                "expected_result": [],
                "comment": "The I-Regular expression given in the JSONPath will match all leap seconds that can appear related to software, according to https://en.wikipedia.org/wiki/List_of_tz_database_time_zones (checked 2026-03-31), as Dublin Mean Time (UTC−00:25:21) was abolished 1916."
              },
              { "type": "success",
                "value" : true
              }
          ]
        },

        { "input": "testcase-3-20260313-1429-isduba-2026-001.json",
          "desc": "replace product category legacy",
          "asserts" : [
              { "type": "warningmsg",
                "substring_matches": [
                    "replaced", "legacy", "product_name"]
              },
              { "type": "jsonpath",
                "query": "$.product_tree.branches..[?(@.category=='legacy')]",
                "expected_result": []
              },
              { "type": "jsonpath",
                "query": "$.product_tree.branches..[?(@.name=='the attic for OurProduct')].category",
                "expected_result": ["product_name"]
              },
              { "type": "success",
                "value" : true
              }
          ]
        },

        { "input": "testcase-4-20260323-1146-isduba-2025-01.json",
          "desc": "Converter cannot create a valid product tree by itself.\nThe category 'vendor' appears twice in the same path (aka it is stacked). Both names are not in the list to be removed by 9.1.18 transformation rules.",
          "asserts": [
              { "type": "errormsg",
                "substring_matches": [
                    "category", "vendor", "invalid product tree",
                    "detected", "stacked branch", "detected"
                    ],
                "comment": "must mention problematic stacked category `vendor` in error message"
              },
              { "type": "success",
                "value" : false
              }
          ]
        },

        { "input": "testcase-4-2-20260323-1146-isduba-2025-01.json",
          "desc": "The category 'vendor' appears three time in the same path (aka 'it is stacked'). Two names are in the list to be removed, so this can be resolved.",
          "asserts": [
              { "type": "warningmsg",
                "substring_matches": [
                    "category", "vendor", "invalid product tree",
                    "detected", "stacked branch", "detected",
                    "resolved"
                    ],
                "comment": "must mention problematic stacked category `vendor` "
              },
              { "type": "jsonpath",
                "query": "$.product_tree.branches..[?(@.name=='Open Source')]",
                "expected_result": []
              },
              { "type": "jsonpath",
                "query": "$.product_tree.branches..[?(@.name=='NOASSERTION')]",
                "expected_result": []
              },
              { "type": "success",
                "value" : true
              }
          ]
        },

        { "input": "testcase-1-20260311-1512-isduba-2026-001.json",
          "desc": "Testing SHOULD warning for /document/publisher/category == 'other'",
          "other_requirement_level": "SHOULD",
          "asserts" : [
              { "type": "warningmsg",
                "substring_matches": ["regroup", "multiplier"]
              },
              { "type": "success",
                "value" : true
              }
          ]
        }
    ]
}
