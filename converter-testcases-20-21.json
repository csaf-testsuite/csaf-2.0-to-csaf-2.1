        {
          "type": "jsonpath",
          "query": "$.product_tree.branches..[?(@.name=='Open Source')]",
          "expected_result": []
        },
        {
          "type": "jsonpath",
          "query": "$.product_tree.branches..[?(@.name=='NOASSERTION')]",
          "expected_result": []
        },
        {
          "type": "success",
          "value": true
        }
